# ─────────────────────────────────────────────────────────────
# Svakarma backend environment
# Copy to `.env` and fill in. The app boots fine with only the
# first two set — integrations default to MOCK mode (no keys).
# ─────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://user:password@localhost:5432/svakarma"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=5000
NODE_ENV=development

# ── SMS / OTP ─────────────────────────────────────────────────
# mock   = no SMS sent; OTP returned to the client for the demo
# twilio = real SMS (requires the three TWILIO_* values + `npm i twilio`)
SMS_PROVIDER=mock
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Payments ──────────────────────────────────────────────────
# mock     = orders + payments simulated locally, signatures real (HMAC-SHA256)
# razorpay = real gateway (requires the RAZORPAY_* values + `npm i razorpay`)
PAYMENT_PROVIDER=mock
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
