### 3e. Account Aggregator (AA) APIs
> **New file to create:** `backend/src/modules/financial-data/aa.routes.ts`

```typescript
// AA consent flow to fetch bank statements from FIPs
router.post('/aa/consent', authMiddleware, async (req, res) => {
  const consentHandle = await aaProvider.createConsent(req.userId); // e.g. Finvu, Setu
  res.json({ success: true, consentHandle });
});

router.get('/aa/fetch', authMiddleware, async (req, res) => {
  const bankData = await aaProvider.fetchData(req.query.consentHandle);
  res.json({ success: true, data: bankData });
});
```

