# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES TEMPLATE
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
#   cp .env.example .env
#
# HOW TO FIND YOUR LAN IP:
#   Windows : run `ipconfig` in CMD → look for "IPv4 Address"
#   Mac/Linux: run `ifconfig` → look for "inet" under en0/wlan0
#
# ⚠️  .env is gitignored — never commit real IPs or secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL to the backend API (include /api suffix)
EXPO_PUBLIC_API_URL=http://<YOUR_LAN_IP>:5000/api
